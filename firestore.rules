rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             : null;
    }

    // Any authenticated user with a recognised role, OR authenticated but no user
    // document yet (bootstrap – allows the first /users/{uid} write).
    function isAnyUser() {
      return isAuthenticated() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        userRole() in ['guest', 'read', 'comment', 'edit', 'moderator', 'admin']
      );
    }

    function isEditOrAdmin() {
      return isAuthenticated() && userRole() in ['edit', 'moderator', 'admin'];
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    // Recipes collection
    match /recipes/{recipeId} {
      // Unauthenticated users may fetch a single non-private recipe by its document ID
      // (e.g. recipes that are part of a shared menu) or query by shareId.
      allow get: if isAnyUser() || !resource.data.isPrivate;
      allow list: if isAnyUser() || resource.data.shareId != null;
      allow create, delete: if isEditOrAdmin();
      allow update: if isEditOrAdmin()
                 || (
                      // Allow anyone (authenticated or guest-rated) to update only the
                      // rating summary fields written by updateRatingSummary().
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['ratingAvg', 'ratingCount'])
                    );

      // Ratings subcollection – anyone (including guests) may read and write their own rating.
      // Guests are identified by a localStorage-generated ID (prefixed 'guest_');
      // authenticated users use their Firebase UID as the document key.
      // Create/update access is granted when the raterKey matches the authenticated user's UID
      // or starts with the expected guest prefix, preventing arbitrary key injection.
      // Delete access is additionally granted to editors, moderators, and admins so they
      // can remove any rating regardless of its raterKey (admin moderation).
      match /ratings/{raterKey} {
        allow read: if true;
        allow create, update: if (request.auth != null && raterKey == request.auth.uid)
                              || raterKey.matches('guest_[a-zA-Z0-9\\-]+');
        allow delete: if (request.auth != null && raterKey == request.auth.uid)
                      || raterKey.matches('guest_[a-zA-Z0-9\\-]+')
                      || isEditOrAdmin();
      }
    }

    // Menus collection
    match /menus/{menuId} {
      // Unauthenticated users may read a menu that has sharing enabled (has a shareId).
      allow get: if isAnyUser() || resource.data.shareId != null;
      allow list: if isAnyUser() || resource.data.shareId != null;
      allow create, update, delete: if isEditOrAdmin();
    }

    // FAQs collection
    match /faqs/{faqId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isAdmin();
    }

    // Groups collection
    match /groups/{groupId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isEditOrAdmin();
    }

    // Shopping lists collection
    match /shoppingLists/{listId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isEditOrAdmin();
    }

    // Role permissions collection – stores feature permissions (fotoscan, webimport) per role.
    // All authenticated users may read; only admins may write.
    match /rolePermissions/{roleId} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAnyUser();
      // Authenticated users may create only their own document and may not
      // self-assign elevated privileges (isAdmin or any role above 'read').
      // The first-user / admin-bootstrap is handled atomically by the
      // createUserProfile Cloud Function (Admin SDK bypasses these rules).
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && !('isAdmin' in request.resource.data)
                    && request.resource.data.role == 'read';
      // Any authenticated user may update their own document; admin may update any.
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // User favorites subcollection
    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // User menu favorites subcollection
    match /users/{userId}/menuFavorites/{favoriteId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if isAnyUser();
      allow create, delete: if isAdmin();
      // Admins may update any settings document.
      // edit/moderator users may update only the list fields in settings/app
      // (cuisineTypes, cuisineGroups, mealCategories, units, portionUnits,
      //  conversionTable, customUnits) – all other fields remain admin-only.
      allow update: if isAdmin()
                 || (
                      isEditOrAdmin()
                      && settingId == 'app'
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['cuisineTypes', 'cuisineGroups', 'mealCategories',
                                     'units', 'portionUnits', 'conversionTable', 'customUnits'])
                    );
    }

    // Button icons collection – each document stores one icon (key = iconKey, value = emoji/base64)
    match /buttonIcons/{iconId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Custom lists collection
    match /customLists/{listId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isAdmin();
    }

    // Category images collection
    match /categoryImages/{imageId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isAdmin();
    }

    // AI Scan rate limiting collection
    match /aiScanLimits/{limitId} {
      allow read: if isEditOrAdmin();
      allow create, update, delete: if isAdmin();
    }

    // App calls audit log collection
    match /appCalls/{callId} {
      allow read: if isAnyUser();
      allow create: if isAnyUser();
      allow update, delete: if isAdmin();
    }

    // Recipe calls audit log collection
    match /recipeCalls/{callId} {
      allow read: if isAnyUser();
      allow create: if isAnyUser();
      allow update, delete: if isAdmin();
    }

    // Cook dates collection - global tracking of when users cooked recipes
    match /cookDates/{cookDateId} {
      allow read: if isAnyUser();
      allow create: if isAnyUser() && request.resource.data.userId == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid)
                    || isEditOrAdmin();
    }

    // Recipe swipe flags collection - tracks user swipe actions (kandidat, geparkt, archiv) for Tagesmenü
    match /recipeSwipeFlags/{flagId} {
      // Returns true when the requesting user is the owner or a member of the given interactive list.
      // This allows list members to read each other's swipe flags for group status computation.
      function isListMemberOf(listId) {
        let listDoc = get(/databases/$(database)/documents/groups/$(listId));
        return listDoc.data.ownerId == request.auth.uid
            || ('memberIds' in listDoc.data && request.auth.uid in listDoc.data.memberIds);
      }

      allow read: if isAuthenticated()
                  && (request.auth.uid == resource.data.userId
                      || isListMemberOf(resource.data.listId));
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.userId)
                    || isAdmin();
    }
  }
}
