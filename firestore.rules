rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             : null;
    }

    // Any authenticated user with a recognised role, OR authenticated but no user
    // document yet (bootstrap – allows the first /users/{uid} write).
    function isAnyUser() {
      return isAuthenticated() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        userRole() in ['guest', 'read', 'comment', 'edit', 'moderator', 'admin']
      );
    }

    function isEditOrAdmin() {
      return isAuthenticated() && userRole() in ['edit', 'moderator', 'admin'];
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    // Recipes collection
    match /recipes/{recipeId} {
      // Unauthenticated users may fetch a single non-private recipe by its document ID
      // (e.g. recipes that are part of a shared menu) or query by shareId.
      allow get: if isAnyUser() || !resource.data.isPrivate;
      allow list: if isAnyUser() || resource.data.shareId != null;
      allow create, delete: if isEditOrAdmin();
      allow update: if isEditOrAdmin()
                 || (
                      // Allow anyone (authenticated or guest-rated) to update only the
                      // rating summary fields written by updateRatingSummary().
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['ratingAvg', 'ratingCount'])
                    );

      // Ratings subcollection – anyone (including guests) may read and write.
      // Guests are identified by a localStorage-generated ID (prefixed 'guest_');
      // authenticated users use their Firebase UID as the document key.
      // Write access is granted when the raterKey matches the authenticated user's UID
      // or starts with the expected guest prefix, preventing arbitrary key injection.
      match /ratings/{raterKey} {
        allow read: if true;
        allow write: if (request.auth != null && raterKey == request.auth.uid)
                     || raterKey.matches('guest_[a-zA-Z0-9\\-]+');
      }
    }

    // Menus collection
    match /menus/{menuId} {
      // Unauthenticated users may read a menu that has sharing enabled (has a shareId).
      allow get: if isAnyUser() || resource.data.shareId != null;
      allow list: if isAnyUser() || resource.data.shareId != null;
      allow create, update, delete: if isEditOrAdmin();
    }

    // FAQs collection
    match /faqs/{faqId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isAdmin();
    }

    // Groups collection
    match /groups/{groupId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isEditOrAdmin();
    }

    // Shopping lists collection
    match /shoppingLists/{listId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isEditOrAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAnyUser();
      // Bootstrap: any authenticated user may create their own document.
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Any authenticated user may update their own document; admin may update any.
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // User favorites subcollection
    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // User menu favorites subcollection
    match /users/{userId}/menuFavorites/{favoriteId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isAdmin();
    }

    // Custom lists collection
    match /customLists/{listId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isAdmin();
    }

    // Category images collection
    match /categoryImages/{imageId} {
      allow read: if isAnyUser();
      allow create, update, delete: if isAdmin();
    }

    // AI Scan rate limiting collection
    match /aiScanLimits/{limitId} {
      allow read: if isEditOrAdmin();
      allow create, update, delete: if isAdmin();
    }

    // App calls audit log collection
    match /appCalls/{callId} {
      allow read: if isAdmin();
      allow create: if isAnyUser();
      allow update, delete: if isAdmin();
    }
  }
}
